#include <iostream> 

double numeros()
{
    std :: cout << "Escreva um número decimal: ";
    double numero;
    std :: cin >> numero;
    
    return numero;
}

char operadores()
{
    std :: cout << "Escolha um operador, o de soma +, subtração -, multiplicação * e divisão / : ";
    char operador{};
    std :: cin >> operador;
    
    return operador;
}

void calcular(double valor1, char operacao, double valor2)
{
    double resultado{};
    
    if (operacao == '+')
        resultado = valor1 + valor2;
    else if (operacao == '-')
        resultado = valor1 - valor2;
    else if (operacao == '*')
        resultado = valor1 + valor2;
    else if (operacao == '/')
        resultado = valor1 / valor2;
    else
        return;
    
    std :: cout << "O resultado da operação é: " << valor1 << ' ' << operacao << ' ' << valor2 << ' ' << resultado << "é =" <<'\n';
}

int main()
{
    double valor1{numeros()};
    double valor2{numeros()};
    
    char operacao{operadores()};
    
    calcular(valor1, operacao, valor2);
    
    return 0;
}
